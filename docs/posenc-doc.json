{"version":3,"kind":"Article","sha256":"30c698278aedac28a99f8bc8dc6454a7081dd22225ead98f0b3268d0e9e22c2b","slug":"posenc-doc","location":"/../modules/posenc/posenc_doc.md","dependencies":[],"frontmatter":{"title":"POSENC - Quadrature and step/direction encoder","content_includes_title":false,"github":"https://github.com/PandABlocks/PandABlocks-FPGA","numbering":{"title":{"offset":1}},"source_url":"https://github.com/PandABlocks/PandABlocks-FPGA/blob/main/modules/posenc/posenc_doc.md","edit_url":"https://github.com/PandABlocks/PandABlocks-FPGA/edit/main/modules/posenc/posenc_doc.md","exports":[{"format":"md","filename":"posenc_doc.md","url":"/PandABlocks-FPGA/docs/build/posenc_doc-b8e82fdefb44ded4551ef0176eac3de4.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"The POSENC block handles the Quadrature and step/direction encoding","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"XSU3T6KpDu"}],"key":"nODcvTY1Em"},{"type":"heading","depth":2,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Fields","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"jU0TGW3xj5"}],"identifier":"fields","label":"Fields","html_id":"fields","implicit":true,"key":"afB2qNpm0S"},{"type":"mystDirective","name":"block_fields","args":"modules/posenc/posenc.block.ini","tight":"after","position":{"start":{"line":6,"column":1},"end":{"line":7,"column":1}},"key":"d7p5ZYGQvM"},{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Quadrature","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"CH4UEVXD8e"}],"identifier":"quadrature","label":"Quadrature","html_id":"quadrature","implicit":true,"key":"yT5qKqHK5q"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"When in the quadrature mode, the module will output signals A and B in different\nstates as it counts up or down. When counting up B will follow A and when\ncounting down A will follow B. The period is the time between an edge on one\nsignal to the next edge of the other signal.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"hLAq9RXYb7"}],"key":"JniUcpqlqv"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"The input is initially set as the value of the INP line when ENABLE goes high.\nThe system will then count to the current value on the INP line, and when it\nreaches this value the output signals will stay as they are.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"jDr68cvIvQ"}],"key":"ihJZq63jeI"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"The state output is ‘0’ while ENABLE is low, ‘1’ when the count is equal to the\nsignal on the INP line and ‘2’ while it is counting towards the INP value.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"Pc66oKzjPb"}],"key":"BDeqfLQOF3"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/posenc/posenc_documentation.timing.ini\n:section: Quadrature rising and falling","tight":"after","position":{"start":{"line":22,"column":1},"end":{"line":25,"column":1}},"key":"WBTGLT76KH"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/posenc/posenc_documentation.timing.ini\n:section: Longer Period Quadrature","tight":true,"position":{"start":{"line":26,"column":1},"end":{"line":29,"column":1}},"key":"YrNyxKs4yp"},{"type":"heading","depth":2,"position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"Step/Direction","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"NNkpwAmnOJ"}],"identifier":"step-direction","label":"Step/Direction","html_id":"step-direction","implicit":true,"key":"poUYsOBwrn"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"In the Step/Direction mode the A output becomes a step output. This goes high on\nevery period for one clock cycle and is low for the remainder of the period. The\nB output becomes the direction output, it is ‘0’ when the internal counter is\nlower than the inputted target value (it is counting up), and ‘1’ when it is\ngreater or equal to.","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"agy84Jn5Ys"}],"key":"Py0P1rp3Wn"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/posenc/posenc_documentation.timing.ini\n:section: Step/Direction","tight":"after","position":{"start":{"line":38,"column":1},"end":{"line":41,"column":1}},"key":"hJvkPKcipk"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/posenc/posenc_documentation.timing.ini\n:section: Longer Period Step/Direction","tight":"before","position":{"start":{"line":42,"column":1},"end":{"line":45,"column":1}},"key":"iEkK0UJWYo"}],"key":"ysXBat5T2e"}],"key":"e2DCeoqvXr"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"PMACENC - Pmac encoder","url":"/pmacenc-doc","group":"PandABlocks-FPGA"},"next":{"title":"PULSE - One-shot pulse delay and stretch","url":"/pulse-doc","group":"PandABlocks-FPGA"}}},"domain":"http://localhost:3000"}