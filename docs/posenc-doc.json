hildren":[{"type":"text","value":"B","key":"NerG9P5Ct2"}],"key":"zhMleGvKXv"},{"type":"tableCell","children":[{"type":"text","value":"bit_out","key":"LjXKwGNNxb"}],"key":"BcdfJifGmK"},{"type":"tableCell","children":[{"type":"text","value":"Quadrature B/Direction output","key":"qvVv7BMJyM"}],"key":"d8RZxnglEe"}],"key":"m8bcmbZ4bB"},{"type":"tableRow","children":[{"type":"tableCell","children":[{"type":"text","value":"STATE","key":"G23ON2Y79w"}],"key":"mEBE7XBrGb"},{"type":"tableCell","children":[{"type":"text","value":"read enum","key":"ES9R0ReA7T"}],"key":"BegE3fe9kW"},{"type":"tableCell","children":[{"type":"text","value":"State of quadrature output","key":"oVmqLJEyIf"}],"key":"tmQSWNNzsj"}],"key":"kMuLc456jz"}],"key":"lVkSIGjilm"},{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Quadrature","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"fBk3upJQIu"}],"identifier":"quadrature","label":"Quadrature","html_id":"quadrature","implicit":true,"key":"zR9Y32Kglr"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"When in the quadrature mode, the module will output signals A and B in different\nstates as it counts up or down. When counting up B will follow A and when\ncounting down A will follow B. The period is the time between an edge on one\nsignal to the next edge of the other signal.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"L7JTHIUS0m"}],"key":"hjEVfD4cQa"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"The input is initially set as the value of the INP line when ENABLE goes high.\nThe system will then count to the current value on the INP line, and when it\nreaches this value the output signals will stay as they are.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"ESMQ80Sc5N"}],"key":"WsdrgRYjwF"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"The state output is ‘0’ while ENABLE is low, ‘1’ when the count is equal to the\nsignal on the INP line and ‘2’ while it is counting towards the INP value.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"KjZFE0s7Rb"}],"key":"pau2ca5LDH"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/3668556c174611fd-608508330bb39391d3238e693e0d125d.svg","alt":"Quadrature rising and falling","class":"dark:hidden","key":"B99WViURYp","urlSource":"../../docs/_build/timing/3668556c174611fd.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/3668556c174611fd.dar-664d6bada99b05382362d0e7a0b04057.svg","alt":"Quadrature rising and falling","class":"hidden dark:block","key":"AjQztBHSFj","urlSource":"../../docs/_build/timing/3668556c174611fd.dark.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/b7b6a42a6f0fd2fc-152798c852a5e32fc36a03415b63ee28.svg","alt":"Longer Period Quadrature","class":"dark:hidden","key":"ORAKCMJ7f1","urlSource":"../../docs/_build/timing/b7b6a42a6f0fd2fc.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/b7b6a42a6f0fd2fc.dar-85d038f3735d0c5a13fd4b7cd3543366.svg","alt":"Longer Period Quadrature","class":"hidden dark:block","key":"v7NGaiHSHU","urlSource":"../../docs/_build/timing/b7b6a42a6f0fd2fc.dark.svg"},{"type":"heading","depth":2,"position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"Step/Direction","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"PiyuoWoJO4"}],"identifier":"step-direction","label":"Step/Direction","html_id":"step-direction","implicit":true,"key":"RI00sxwj1b"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"In the Step/Direction mode the A output becomes a step output. This goes high on\nevery period for one clock cycle and is low for the remainder of the period. The\nB output becomes the direction output, it is ‘0’ when the internal counter is\nlower than the inputted target value (it is counting up), and ‘1’ when it is\ngreater or equal to.","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"TDbuHATsmO"}],"key":"C6MpUsB7xb"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/1da4df19b9abf16c-1309f9ec355b7d0a041cec8c2535b244.svg","alt":"Step/Direction","class":"dark:hidden","key":"RiHdjjAL8y","urlSource":"../../docs/_build/timing/1da4df19b9abf16c.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/1da4df19b9abf16c.dar-650354999d8cfad2bde996963ec867eb.svg","alt":"Step/Direction","class":"hidden dark:block","key":"lOLF5lNY9h","urlSource":"../../docs/_build/timing/1da4df19b9abf16c.dark.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/7a56006e41f44d87-da682d5dd47f17243f415ecb841c90e5.svg","alt":"Longer Period Step/Direction","class":"dark:hidden","key":"lDdCfdiZ21","urlSource":"../../docs/_build/timing/7a56006e41f44d87.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/7a56006e41f44d87.dar-9a44273bf65c023417c32a775897a972.svg","alt":"Longer Period Step/Direction","class":"hidden dark:block","key":"jWi8BINKdQ","urlSource":"../../docs/_build/timing/7a56006e41f44d87.dark.svg"}],"key":"Cl2P6KNnEa"}],"key":"yOXryjg77n"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"PMACENC - Pmac encoder","url":"/pmacenc-doc","group":"PandABlocks-FPGA"},"next":{"title":"PULSE - One-shot pulse delay and stretch","url":"/pulse-doc","group":"PandABlocks-FPGA"}}},"domain":"http://localhost:3000"}