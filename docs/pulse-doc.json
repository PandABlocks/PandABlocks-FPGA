/pulse/pulse.timing.ini\n:section: Pulse delay and stretch","tight":"after","position":{"start":{"line":45,"column":1},"end":{"line":48,"column":1}},"key":"PBS3GnoHqs"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"The output pulses are queued, so multiple pulses can be queued before output:","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"CUirC8rQx2"}],"key":"SRc4KCvqUw"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/pulse/pulse.timing.ini\n:section: Pulse train stretched and delayed","tight":"after","position":{"start":{"line":51,"column":1},"end":{"line":54,"column":1}},"key":"Axyi7TeJ0L"},{"type":"paragraph","position":{"start":{"line":55,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"The TRIG_EDGE field can be used to select whether an input pulse queues an\noutput on rising, falling, or both edges:","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"ggQvKtLO48"}],"key":"tiGo2vaEbK"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/pulse/pulse.timing.ini\n:section: Pulse stretching with no delay activate on rising edge","tight":"after","position":{"start":{"line":58,"column":1},"end":{"line":61,"column":1}},"key":"UidnCtIqZ0"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/pulse/pulse.timing.ini\n:section: Pulse stretching with no delay activate on falling edge","tight":true,"position":{"start":{"line":62,"column":1},"end":{"line":65,"column":1}},"key":"G66VAFyDd4"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/pulse/pulse.timing.ini\n:section: Pulse stretching with no delay activate on both edges","tight":true,"position":{"start":{"line":66,"column":1},"end":{"line":69,"column":1}},"key":"rinEaImqBC"},{"type":"paragraph","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[{"type":"text","value":"0 < WIDTH < 5 will be treated as WIDTH=5:","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"ImiUR72Kyk"}],"key":"Rnc9AuLEZm"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/pulse/pulse.timing.ini\n:section: No delay means a WIDTH of 5 or more is required","tight":"after","position":{"start":{"line":72,"column":1},"end":{"line":75,"column":1}},"key":"dX1AriAzE2"},{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"If PULSES > 1 then multiple output pulses will be generated, separated by STEP:","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"RgihHSDGpJ"}],"key":"VYT9zKC3Ba"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/pulse/pulse.timing.ini\n:section: Multiple pulses with no delay","tight":"after","position":{"start":{"line":78,"column":1},"end":{"line":81,"column":1}},"key":"nOGpNSoVWP"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/pulse/pulse.timing.ini\n:section: Small delay width combination","tight":true,"position":{"start":{"line":82,"column":1},"end":{"line":85,"column":1}},"key":"WHenFuEyhY"},{"type":"heading","depth":2,"position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"children":[{"type":"text","value":"Pulse period error","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"QRf7qTNrqu"}],"identifier":"pulse-period-error","label":"Pulse period error","html_id":"pulse-period-error","implicit":true,"key":"XaUOnmoaE5"},{"type":"paragraph","position":{"start":{"line":88,"column":1},"end":{"line":90,"column":1}},"children":[{"type":"text","value":"The following example shows what happens when the period between pulses is too\nshort. To avoid running output pulses together, the DROPPED field is incremented\nand the input is dropped:","position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"key":"KeKdrddBdX"}],"key":"DVDFQuVOf1"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/pulse/pulse.timing.ini\n:section: Stretched and delayed pulses too close together","tight":"after","position":{"start":{"line":92,"column":1},"end":{"line":95,"column":1}},"key":"l5cPWVoxbM"},{"type":"paragraph","position":{"start":{"line":96,"column":1},"end":{"line":97,"column":1}},"children":[{"type":"text","value":"The queue length is 255, so if QUEUED reaches 255 then any new pulse will\nbe dropped and also increment DROPPED.","position":{"start":{"line":96,"column":1},"end":{"line":96,"column":1}},"key":"vtaZdr2et3"}],"key":"sitfJF0om5"},{"type":"paragraph","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"children":[{"type":"text","value":"The DROPPED count is zeroed on rising edge of ENABLE.","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"FbrpaagumO"}],"key":"SqO0W3eo3S"},{"type":"heading","depth":2,"position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"children":[{"type":"text","value":"Enabling the Block","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"key":"WHcJQCl34w"}],"identifier":"enabling-the-block","label":"Enabling the Block","html_id":"enabling-the-block","implicit":true,"key":"z56RAa1utj"},{"type":"paragraph","position":{"start":{"line":103,"column":1},"end":{"line":104,"column":1}},"children":[{"type":"text","value":"There is an Enable signal that stops the Block from producing signals. Edges\nmust occur while Enable is high to trigger a pulse creation","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"MDlnJshRj7"}],"key":"WD5oPpfw3s"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/pulse/pulse.timing.ini\n:section: No pulses if disabled","tight":"after","position":{"start":{"line":106,"column":1},"end":{"line":109,"column":1}},"key":"gCX3o2Jb5U"},{"type":"p