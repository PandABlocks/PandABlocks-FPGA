{"version":3,"kind":"Article","sha256":"68354d74e331bfa6c87b48fb45513fb900b3eae6b9ec0f41ef3d2ca14f6f2882","slug":"pulse-doc","location":"/../modules/pulse/pulse_doc.md","dependencies":[],"frontmatter":{"title":"PULSE - One-shot pulse delay and stretch","content_includes_title":false,"github":"https://github.com/PandABlocks/PandABlocks-FPGA","numbering":{"title":{"offset":1}},"source_url":"https://github.com/PandABlocks/PandABlocks-FPGA/blob/main/modules/pulse/pulse_doc.md","edit_url":"https://github.com/PandABlocks/PandABlocks-FPGA/edit/main/modules/pulse/pulse_doc.md","exports":[{"format":"md","filename":"pulse_doc.md","url":"/PandABlocks-FPGA/docs/build/pulse_doc-36b6b2bcd0e2127613b5c97f8c1c8c65.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"A PULSE block produces configurable width output pulses with an optional delay\nbased on its parameters. It operates in one of two modes:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"GrYUqn0hg2"}],"key":"q3vtLoRqFl"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":6,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"If WIDTH=0, then it acts as a delay line. The input pulse train will just be\nreplayed after the given DELAY","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"oYGVaoj6PP"}],"key":"KOEi1gU1ez"}],"key":"dlkCTMc9ZZ"},{"type":"listItem","spread":true,"position":{"start":{"line":8,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"If WIDTH is non-zero, then each pulse edge that matches TRIG_EDGE will be\ndelayed by the specified DELAY, then generate NPULSES pulses of width WIDTH,\nwith rising edges separated by STEP","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"BbP49IUY0z"}],"key":"Nq11w61plS"}],"key":"s7xV066jkJ"}],"key":"OlrzzO3PtD"},{"type":"heading","depth":2,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Fields","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"snfOms1p5J"}],"identifier":"fields","label":"Fields","html_id":"fields","implicit":true,"key":"RsKUy4Egqt"},{"type":"mystDirective","name":"block_fields","args":"modules/pulse/pulse.block.ini","tight":"after","position":{"start":{"line":14,"column":1},"end":{"line":15,"column":1}},"key":"DLIqznmPmR"},{"type":"heading","depth":2,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Delay line","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"hmhX1fuwKn"}],"identifier":"delay-line","label":"Delay line","html_id":"delay-line","implicit":true,"key":"P2k6RaFPRT"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"If WIDTH=0, then the Block acts as a delay line. DELAY must either be 0 or\n5+ clock ticks. TRIG_EDGE, STEP, and NPULSES are ignored.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"bRfh9k1Tsm"}],"key":"f0pGZR4vTk"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"If DELAY=0 the Block is a simple pass through:","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"B9kIQtc3XP"}],"key":"vCA9Qqsyrw"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/pulse/pulse.timing.ini\n:section: No delay or stretch","tight":"after","position":{"start":{"line":23,"column":1},"end":{"line":26,"column":1}},"key":"XvoOshGBPp"},{"typ