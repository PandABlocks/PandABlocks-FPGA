{"version":3,"kind":"Article","sha256":"11bbfb8fd073ce07817dfb604412488857042c4ebbd2a5b8ecbd3effcec5006b","slug":"div-doc","location":"/../modules/div/div_doc.md","dependencies":[],"frontmatter":{"title":"DIV - Pulse divider","content_includes_title":false,"github":"https://github.com/PandABlocks/PandABlocks-FPGA","numbering":{"title":{"offset":1}},"source_url":"https://github.com/PandABlocks/PandABlocks-FPGA/blob/main/modules/div/div_doc.md","edit_url":"https://github.com/PandABlocks/PandABlocks-FPGA/edit/main/modules/div/div_doc.md","exports":[{"format":"md","filename":"div_doc.md","url":"/PandABlocks-FPGA/docs/build/div_doc-f7e03d36b90694810a9342b36f33bb19.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"A DIV block is a 32-bit pulse divider that can divide a pulse train between two\noutputs. It has an internal counter that counts from 0 to DIVISOR-1. On each\nrising edge of INP, if counter = DIVISOR-1, then it is set to 0 and the pulse is\nsent to OUTD, otherwise it is sent to OUTN. Change in any parameter causes the\nblock to be reset.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"MWC4vlPgeb"}],"key":"inXRm8o8mc"},{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Fields","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"b5CvsIPwjP"}],"identifier":"fields","label":"Fields","html_id":"fields","implicit":true,"key":"x1vScDACBf"},{"type":"mystDirective","name":"block_fields","args":"modules/div/div.block.ini","tight":"after","position":{"start":{"line":11,"column":1},"end":{"line":12,"column":1}},"key":"duIdRQflcl"},{"type":"heading","depth":2,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Which output do pulses go 