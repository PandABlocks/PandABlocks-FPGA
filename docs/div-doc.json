ue":":path: modules/div/div.timing.ini\n:section: Reset conditions","position":{"start":{"line":34,"column":1},"end":{"line":37,"column":1}},"key":"AH4c0u1mMb"}],"key":"k98WvEQfqI"}],"key":"bNvauvmT7E"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"DIO - Digital Input/Output","url":"/dio-doc","group":"PandABlocks-FPGA"},"next":{"title":"DO - Digital Output","url":"/do-doc","group":"PandABlocks-FPGA"}}},"domain":"http://localhost:3000"}