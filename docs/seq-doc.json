Directive","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: 3 evenly spaced pulses","tight":"after","position":{"start":{"line":40,"column":1},"end":{"line":43,"column":1}},"key":"p0qiuiB7dg"},{"type":"paragraph","position":{"start":{"line":44,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"We can also use it to generate irregular streams of pulses on different outputs\nby adding more lines to the table. Note that OUTB which was high at the end\nof Phase2 of the first line remains high in Phase1 of the second line:","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"T3wthDRe0x"}],"key":"XwuVUzOru3"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: Irregular pulses","tight":"after","position":{"start":{"line":48,"column":1},"end":{"line":51,"column":1}},"key":"IZuUr54sJ5"},{"type":"paragraph","position":{"start":{"line":52,"column":1},"end":{"line":53,"column":1}},"children":[{"type":"text","value":"And we can set repeats on the entire table too. Note that in the second line of\nthis table we have suppressed phase1 by setting its time to 0:","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"U9KEespI8y"}],"key":"L9xT17f3o3"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: Table repeats","tight":"after","position":{"start":{"line":55,"column":1},"end":{"line":58,"column":1}},"key":"DnXs7PeKX3"},{"type":"paragraph","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"children":[{"type":"text","value":"There are 6 outputs which allow for complex patterns to be generated:","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"ahLO3TsiVj"}],"key":"qGZ2gO1grI"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: Using all 6 outputs","tight":"after","position":{"start":{"line":61,"column":1},"end":{"line":64,"column":1}},"key":"ufzylwxRa8"},{"type":"heading","depth":2,"position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"children":[{"type":"text","value":"Statemachine","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"SVojXbGPzD"}],"identifier":"statemachine","label":"Statemachine","html_id":"statemachine","implicit":true,"key":"Kk9Bt8jyJa"},{"type":"paragraph","position":{"start":{"line":67,"column":1},"end":{"line":69,"column":1}},"children":[{"type":"text","value":"There is an internal statemachine that controls which phase is currently being\noutput. It has a number of transitions that allow it to skip PHASE1 if there is\nnone, or skip WAIT_TRIGGER if there is no trigger condition.","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"key":"R2AgQBlYYI"}],"key":"QPGn0B04DV"},{"type":"code","lang":"graphviz","value":"digraph pcomp_sm {\n     WAIT_ENABLE [label=\"State 0\\nWAIT_ENABLE\"]\n     UNREADY [label=\"State 1\\nUNREADY\"]\n     WAIT_TRIGGER [label=\"State 2\\nWAIT_TRIGGER\"]\n     PHASE1 [label=\"State 3\\nPHASE1\"]\n     PHASE2 [label=\"State 4\\nPHASE2\"]\n\n     WAIT_ENABLE -> UNREADY [label=\" TABLE load started \"]\n     WAIT_ENABLE -> WAIT_TRIGGER [label=\" rising ENABLE and trigger not met \"]\n     WAIT_ENABLE -> PHASE1 [label=\" rising ENABLE and trigger met \"]\n     WAIT_ENABLE -> PHASE2 [label=\" rising ENABLE and trigger met and no phase1 \"]\n\n     UNREADY -> WAIT_ENABLE [label=\" TABLE load complete \"]\n\n     WAIT_TRIGGER -> UNREADY [label=\" TABLE load started \"]\n     WAIT_TRIGGER -> PHASE1 [label=\" trigger met \"]\n     WAIT_TRIGGER -> PHASE2 [label=\" trigger met and no phase1 \"]\n\n     PHASE1 -> UNREADY [label=\" TABLE load started \"]\n     PHASE1 -> PHASE2 [label=\" time1 elapsed \"]\n\n     PHASE2 -> UNREADY [label=\" TABLE load started \"]\n     PHASE2 -> WAIT_TRIGGER [label=\" next trigger not met \"]\n     PHASE2 -> PHASE1 [label=\" next trigger met \"]\n     PHASE2 -> PHASE2 [label=\" next trigger met and no phase1 \"]\n}","position":{"start":{"line":71,"column":1},"end":{"line":98,"column":1}},"key":"gDZ7vVbSyq"},{"type":"heading","depth":2,"position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"children":[{"type":"text","value":"External trigger sources","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"G2WS2LIgrG"}],"identifier":"external-trigger-sources","label":"External trigger sources","html_id":"external-trigger-sources","implicit":true,"key":"B3QICvMCpn"},{"type":"paragraph","position":{"start":{"line":101,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"text","value":"The trigger column in the table allows an optional trigger condition to be\nwaited on before the phased times are started. The trigger condition is checked\non each repeat of the line, but not checked during phase1 and phase2. You can\nsee when the Block is waiting for a trigger signal as it will enter the\nWAIT_TRIGGER(2) state:","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"key":"AQZZDQ2vKE"}],"key":"XFeXAswvy2"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: Waiting on bit inputs","tight":"after","position":{"start":{"line":107,"column":1},"end":{"line":110,"column":1}},"key":"XK3Of21vyr"},{"type":"paragraph","position":{"start":{"line":111,"column":1},"end":{"line":112,"column":1}},"children":[{"type":"text","value":"You can also use a position field as a trigger condition in the same way, this\nis useful to do a table based position compare:","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"hLnE6t3pq4"}],"key":"s7HQdm06cm"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: Table based position compare","tight":"after","position":{"start":{"line":114,"column":1},"end":{"line":117,"column":1}},"key":"djRvBdZT4K"},{"type":"heading","depth":2,"position":{"start":{"line":118,"column":1},"end":{"line":118,"column":1}},"children":[{"type":"text","value":"Prescaler","position":{"start":{"line":118,"column":1},"end":{"line":118,"column":1}},"key":"LDsOWDXhUY"}],"identifier":"prescaler","label":"Prescaler","html_id":"prescaler","implicit":true,"key":"IWoerC0mgh"},{"type":"paragraph","position":{"start":{"line":120,"column":1},"end":{"line":122,"column":1}},"children":[{"type":"text","value":"Each row of the table gives a time value for the phases. This value can be\nscaled with a block wide prescaler to allow a frame to be longer than\n2**32 * 8e-9 = about 34 seconds. For example:","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"EcAHvc9J7l"}],"key":"qgyTOtsFBv"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: Prescaled pulses","tight":"after","position":{"start":{"line":124,"column":1},"end":{"line":127,"column":1}},"key":"ZH2quUSHmT"},{"type":"heading","depth":2,"position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"children":[{"type":"text","value":"Interrupting a sequence","position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"key":"lEPGJflOEs"}],"identifier":"interrupting-a-sequence","label":"Interrupting a sequence","html_id":"interrupting-a-sequence","implicit":true,"key":"NvLhlKqeN1"},{"type":"paragraph","position":{"start":{"line":130,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"text","value":"Setting the repeats on a table row to 0 will cause it to iterate until\ninterrupted by a falling ENABLE signal:","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"NDuor0RMZu"}],"key":"bSOSboCivn"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: Infinite repeats of a row interrupted","tight":"after","position":{"start":{"line":133,"column":1},"end":{"line":136,"column":1}},"key":"H2MdD74BXW"},{"type":"paragraph","position":{"start":{"line":137,"column":1},"end":{"line":138,"column":1}},"children":[{"type":"text","value":"In a similar way, REPEATS=0 on a table will cause the whole table to be\niterated until interrupted by a falling ENABLE signal:","position":{"start":{"line":137,"column":1},"end":{"line":137,"column":1}},"key":"RVL0OlcSHk"}],"key":"W7nktGRXSe"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: Infinite repeats of a table interrupted","tight":"after","position":{"start":{"line":140,"column":1},"end":{"line":143,"column":1}},"key":"eL7x2caVaC"},{"type":"paragraph","position":{"start":{"line":144,"column":1},"end":{"line":144,"column":1}},"children":[{"type":"text","value":"And a rising edge of the ENABLE will re-run the same table from the start:","position":{"start":{"line":144,"column":1},"end":{"line":144,"column":1}},"key":"NZTkavVIAx"}],"key":"ToCOPsNgwi"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: Restarting the same table","tight":"after","position":{"start":{"line":146,"column":1},"end":{"line":149,"column":1}},"key":"Qz9Np4gtI7"},{"type":"heading","depth":2,"position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"children":[{"type":"text","value":"Streaming tables","position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"key":"EmtJMp2hj9"}],"identifier":"streaming-tables","label":"Streaming tables","html_id":"streaming-tables","implicit":true,"key":"cUxXHTebtD"},{"type":"paragraph","position":{"start":{"line":152,"column":1},"end":{"line":156,"column":1}},"children":[{"type":"text","value":"When TABLE_LENGTH has the most significant bit set, it indicates there will\nbe one more table pushed. The condition in which a new table can be pushed\nis signaled via an interrupt. When the last table is pushed (indicated by\nTABLE_LENGTH’s most significant bit cleared), the sequencer will repeat that\ntable according to the value of the REPEATS register.","position":{"start":{"line":152,"column":1},"end":{"line":152,"column":1}},"key":"lMwOdwCeTm"}],"key":"X9xJi9JO0T"},{"type":"mystDirective","name":"timing_plot","value":":path: modules/seq/seq_documentation.timing.ini\n:section: Streaming tables","position":{"start":{"line":158,"column":1},"end":{"line":161,"column":1}},"key":"MZ1JXLIPao"}],"key":"LX9prBW2dx"}],"key":"Ekihsa3vyY"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"QDEC - Quadrature Decoder","url":"/qdec-doc","group":"PandABlocks-FPGA"},"next":{"title":"SFP_DLS_EVENTR - SFP Event Receiver Module","url":"/sfp-dls-eventr-doc","group":"PandABlocks-FPGA"}}},"domain":"http://localhost:3000"}