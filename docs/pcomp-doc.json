first pulse until we cross\nSTART in the correct direction:","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"QUmYlN2uDI"}],"key":"ZGHpQy77Qe"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/9427e39313556f07-b71875147b4b9ce5570917005b696677.svg","alt":"Enabled while crossing in wrong direction","class":"dark:hidden","key":"nlI9Q1zjpG","urlSource":"../../docs/_build/timing/9427e39313556f07.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/9427e39313556f07.dar-33b45fc2b32a7674215f4b75c1850290.svg","alt":"Enabled while crossing in wrong direction","class":"hidden dark:block","key":"d9rLAP709h","urlSource":"../../docs/_build/timing/9427e39313556f07.dark.svg"},{"type":"paragraph","position":{"start":{"line":37,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Moving in a negative direction works in a similar way. Note that WIDTH and\nPULSE still have positive values:","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"ymHsbNNQiD"}],"key":"M8dEyzfF54"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/52979178e7966a05-a8849fef7724c189a798f0f4a6ce1d58.svg","alt":"2 Pulses in a -ve direction","class":"dark:hidden","key":"MPmjlRx3oe","urlSource":"../../docs/_build/timing/52979178e7966a05.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/52979178e7966a05.dar-b2c939d0a5d5d84bd6c9a7b69fbb6b51.svg","alt":"2 Pulses in a -ve direction","class":"hidden dark:block","key":"xdDLKaA0YK","urlSource":"../../docs/_build/timing/52979178e7966a05.dark.svg"},{"type":"heading","depth":2,"position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"Internal statemachine","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"DTuIYtxb6t"}],"identifier":"internal-statemachine","label":"Internal statemachine","html_id":"internal-statemachine","implicit":true,"key":"HEd0ijakTH"},{"type":"paragraph","position":{"start":{"line":46,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"The Block has an internal statemachine that is exposed as a parameter, allowing\nthe user to see what the Block is currently doing:","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"oztjsedHq4"}],"key":"NhJs5e6lyC"},{"type":"code","lang":"graphviz","value":"digraph pcomp_sm {\n     WAIT_ENABLE [label=\"State 0\\nWAIT_ENABLE\",]\n     WAIT_DIR [label=\"State 1\\nWAIT_DIR\"]\n     WAIT_PRE_START [label=\"State 2\\nWAIT_PRE_START\"]\n     WAIT_RISING [label=\"State 3\\nWAIT_RISING\"]\n     WAIT_FALLING [label=\"State 4\\nWAIT_FALLING\"]\n\n     WAIT_ENABLE -> WAIT_DIR [label=\"rising ENABLE\\n & DIR=EITHER \",fontsize=13]\n     WAIT_ENABLE -> WAIT_PRE_START [label=\" rising\\n ENABLE \",fontsize=13]\n     WAIT_ENABLE -> WAIT_FALLING [label=\"rising\\nENABLE\\n& RELATIVE\\n& START=0\",fontsize=13]\n\n     WAIT_DIR -> WAIT_ENABLE [label=\" Can't guess\\n DIR \\n or Disabled \"]\n     [fontsize=13]\n     WAIT_DIR -> WAIT_PRE_START [label=\" DIR\\n calculated \",fontsize=13]\n     WAIT_DIR -> WAIT_FALLING [label=\" DIR calculated \\n & \\n no PRE_START\"]\n     [fontsize=13]\n\n     WAIT_PRE_START -> WAIT_ENABLE [label=\" Disabled \"][fontsize=13]\n     WAIT_PRE_START -> WAIT_RISING [label=\" < PRE_START > \"][fontsize=13]\n\n     WAIT_RISING -> WAIT_ENABLE [label=\"jump >\\nWIDTH + STEP\\n or Disabled \"]\n     [fontsize=13]\n     WAIT_RISING -> WAIT_FALLING [label=\" >= pulse \",fontsize=13]\n\n     WAIT_FALLING -> WAIT_ENABLE\n     [label=\" jump > \\nWIDTH + STEP\\n or Finished \\nor Disabled\",fontsize=13]\n     WAIT_FALLING -> WAIT_RISING [label=\" >= pulse \\n + WIDTH \"]\n     [fontsize=13]\n}","position":{"start":{"line":49,"column":1},"end":{"line":79,"column":1}},"key":"FOQhOpYwUN"},{"type":"heading","depth":2,"position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Not generating a pulse more than once","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"BjSkPdVJsX"}],"identifier":"not-generating-a-pulse-more-than-once","label":"Not generating a pulse more than once","html_id":"not-generating-a-pulse-more-than-once","implicit":true,"key":"TrtL3PP2nh"},{"type":"paragraph","position":{"start":{"line":82,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"text","value":"A key part of position compare is not generating a pulse at a position more\nthan once. This is to deal with noisy encoders:","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"key":"xEURThnFJr"}],"key":"anGo4JcfpX"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/11d850cf22108a3f-c096027b18ae1c92274c646a656a502a.svg","alt":"Only produce pulse once","class":"dark:hidden","key":"NbLpU1sm46","urlSource":"../../docs/_build/timing/11d850cf22108a3f.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/11d850cf22108a3f.dar-5ebeb1e6fe79e637256d617d2c1ebe3e.svg","alt":"Only produce pulse once","class":"hidden dark:block","key":"XgYoCXEZM7","urlSource":"../../docs/_build/timing/11d850cf22108a3f.dark.svg"},{"type":"paragraph","position":{"start":{"line":89,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"text","value":"This means that care is needed if using direction sensing or relying on the\ndirectionality of the encoder when passing the start position. For example,\nif we approach START from the negative direction while doing a positive\nposition compare, then jitter back over the start position, we will generate\nstart at the wrong place. If you look carefully at the statemachine you will\nsee that the Block crossed into WAIT_START when INP < 4 (START), which is too\nsoon for this amount of jitter:","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"ui0QDYd6aR"}],"key":"D7BmgR5aZh"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/1b7e7451d62bb794-1c107019e5e2857bee52547f0a70a4fe.svg","alt":"Jittering over the start position","class":"dark:hidden","key":"GupBRAgMEX","urlSource":"../../docs/_build/timing/1b7e7451d62bb794.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/1b7e7451d62bb794.dar-5a8312a83b1c5e6bcf7fc38770d3bc66.svg","alt":"Jittering over the start position","class":"hidden dark:block","key":"t1buhmSFXB","urlSource":"../../docs/_build/timing/1b7e7451d62bb794.dark.svg"},{"type":"paragraph","position":{"start":{"line":101,"column":1},"end":{"line":103,"column":1}},"children":[{"type":"text","value":"We can fix this by adding to the PRE_START deadband which the encoder has to\ncross in order to advance to the WAIT_START state. Now INP < 2 (START-PRE_START)\nis used for the condition of crossing into WAIT_START:","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"key":"YYemPmiMsV"}],"key":"fLivS2sOvy"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/6347376b3e930960-307b5a1098eadab71e1d20b7c22e9e59.svg","alt":"Avoiding jitter problem with PRE_START","class":"dark:hidden","key":"gS5ZisZuVr","urlSource":"../../docs/_build/timing/6347376b3e930960.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/6347376b3e930960.dar-f167abb0b6238ab76c0fab44352387a7.svg","alt":"Avoiding jitter problem with PRE_START","class":"hidden dark:block","key":"fVNLe6WZSX","urlSource":"../../docs/_build/timing/6347376b3e930960.dark.svg"},{"type":"heading","depth":2,"position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"children":[{"type":"text","value":"Guessing the direction","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"M0O0XDXq7K"}],"identifier":"guessing-the-direction","label":"Guessing the direction","html_id":"guessing-the-direction","implicit":true,"key":"E3YcB7OVR8"},{"type":"paragraph","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"children":[{"type":"text","value":"We can also ask to the Block to calculate direction for us:","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"qhfSiPwU2j"}],"key":"Q8svMCcmfJ"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/d90f2d3d201b6851-1e11a31b8d860f4b0e7cfe8fc2891104.svg","alt":"Calculate direction to be -ve","class":"dark:hidden","key":"DXgWoCoHjC","urlSource":"../../docs/_build/timing/d90f2d3d201b6851.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/d90f2d3d201b6851.dar-4ac1cd91d4e65a13f4e6736ff7372c20.svg","alt":"Calculate direction to be -ve","class":"hidden dark:block","key":"RJWSWU6nPi","urlSource":"../../docs/_build/timing/d90f2d3d201b6851.dark.svg"},{"type":"paragraph","position":{"start":{"line":117,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"text","value":"This is a one time calculation of direction at the start of operation, once\nthe encoder has been moved enough to guess the direction then it is fixed until\nthe Block has finished producing pulses:","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"Wkl7dxizZw"}],"key":"RSmappAV3Y"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/8ee39d8b98bec921-112638a2ead79e900d71c34740b0a67b.svg","alt":"Calculate direction to be +ve","class":"dark:hidden","key":"ecYgoF65Pq","urlSource":"../../docs/_build/timing/8ee39d8b98bec921.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/8ee39d8b98bec921.dar-954908ad625f552c33a2a342e4804246.svg","alt":"Calculate direction to be +ve","class":"hidden dark:block","key":"e91JsIvobq","urlSource":"../../docs/_build/timing/8ee39d8b98bec921.dark.svg"},{"type":"heading","depth":2,"position":{"start":{"line":125,"column":1},"end":{"line":125,"column":1}},"children":[{"type":"text","value":"Interrupting a scan","position":{"start":{"line":125,"column":1},"end":{"line":125,"column":1}},"key":"qTkv39s3TC"}],"identifier":"interrupting-a-scan","label":"Interrupting a scan","html_id":"interrupting-a-scan","implicit":true,"key":"h0kL4O7Vmh"},{"type":"paragraph","position":{"start":{"line":127,"column":1},"end":{"line":129,"column":1}},"children":[{"type":"text","value":"When the ENABLE input is set low the output will cease. This will happen even if\nthe ENABLE is set low when there are still cycles of the output pulse to\ngenerate, or if the ENABLE = 0 is set at the same time as a position match.","position":{"start":{"line":127,"column":1},"end":{"line":127,"column":1}},"key":"Hxhgfmht2T"}],"key":"UnSeq5PeSX"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/4edb81e16b0b7286-d5496b116c654f167b1673638cb0b57c.svg","alt":"Disable after start","class":"dark:hidden","key":"yftin5pd4p","urlSource":"../../docs/_build/timing/4edb81e16b0b7286.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/4edb81e16b0b7286.dar-003632f005d573b9b8dbeac69eba337b.svg","alt":"Disable after start","class":"hidden dark:block","key":"GBEyy5PCPC","urlSource":"../../docs/_build/timing/4edb81e16b0b7286.dark.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/c52b866ec3bbf4b9-60d32eece63810ce3ee6d204f51e7caa.svg","alt":"Disable with start","class":"dark:hidden","key":"cidjI5W1S2","urlSource":"../../docs/_build/timing/c52b866ec3bbf4b9.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/c52b866ec3bbf4b9.dar-7ac41b56cede3274fc19bc57d266bb45.svg","alt":"Disable with start","class":"hidden dark:block","key":"CzvLPIxztB","urlSource":"../../docs/_build/timing/c52b866ec3bbf4b9.dark.svg"},{"type":"heading","depth":2,"position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"text","value":"Position compare on absolute values","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"kFyCx5Ig6T"}],"identifier":"position-compare-on-absolute-values","label":"Position compare on absolute values","html_id":"position-compare-on-absolute-values","implicit":true,"key":"j4GoGaZUBa"},{"type":"paragraph","position":{"start":{"line":141,"column":1},"end":{"line":144,"column":1}},"children":[{"type":"text","value":"Doing position compare on an absolute value adds additional challenges, as\nwe are not guaranteed to see every transition. It works in much the same\nway as the previous examples, but we trigger on greater than or equal rather\nthan just greater than:","position":{"start":{"line":141,"column":1},"end":{"line":141,"column":1}},"key":"VUm2yHwWt2"}],"key":"aGpP4hOVn5"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/6518c204a10fc8e9-fa766557db03e1131de80cd1cd32e396.svg","alt":"Absolute Pulses in a +ve direction","class":"dark:hidden","key":"nUgQqfyFGO","urlSource":"../../docs/_build/timing/6518c204a10fc8e9.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/6518c204a10fc8e9.dar-fdc2ae20934022a3599ce902c64b3433.svg","alt":"Absolute Pulses in a +ve direction","class":"hidden dark:block","key":"akXIacClZj","urlSource":"../../docs/_build/timing/6518c204a10fc8e9.dark.svg"},{"type":"paragraph","position":{"start":{"line":150,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"But what should the Block do if the output is 0 and the position jumps by\nenough to trigger a transition to 1 and then back to 0? We handle this by\nsetting HEALTH=“Error: Position jumped by more than STEP” and aborting\nthe compare:","position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"key":"eAOC7oa99Y"}],"key":"q0xVtctlJC"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/bfea3a1e5976b6be-a989df9082d8916ed55c9c21b3aeae06.svg","alt":"Error skipping when OUT=0","class":"dark:hidden","key":"PeAa9Ay5EU","urlSource":"../../docs/_build/timing/bfea3a1e5976b6be.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/bfea3a1e5976b6be.dar-9d91fb12e3674afa44917dddd7429e12.svg","alt":"Error skipping when OUT=0","class":"hidden dark:block","key":"JJra6stOxF","urlSource":"../../docs/_build/timing/bfea3a1e5976b6be.dark.svg"},{"type":"paragraph","position":{"start":{"line":159,"column":1},"end":{"line":160,"column":1}},"children":[{"type":"text","value":"Likewise if the output is 1 and the position causes us to need to produce a 0\nthen 1:","position":{"start":{"line":159,"column":1},"end":{"line":159,"column":1}},"key":"G9FbHxdhI3"}],"key":"wOWE5G8XTq"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/8fa5699627ee8c7a-53112cf29e2058104cd515c616ff8430.svg","alt":"Error skipping when OUT=1","class":"dark:hidden","key":"F4oVClbxqb","urlSource":"../../docs/_build/timing/8fa5699627ee8c7a.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/8fa5699627ee8c7a.dar-df6b7640a4f6006d5e66458b2b96cdd3.svg","alt":"Error skipping when OUT=1","class":"hidden dark:block","key":"VXq12d7b4t","urlSource":"../../docs/_build/timing/8fa5699627ee8c7a.dark.svg"},{"type":"paragraph","position":{"start":{"line":166,"column":1},"end":{"line":166,"column":1}},"children":[{"type":"text","value":"And if we skipped a larger number of points we get the same error:","position":{"start":{"line":166,"column":1},"end":{"line":166,"column":1}},"key":"pThQYRTbGD"}],"key":"tvIbGjO79O"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/7cc7de78927f0a27-0e6329b04c9725e3cd912bcbdc3aa429.svg","alt":"Error is produced after skipping more than 2 compare points","class":"dark:hidden","key":"CtLeq0lQau","urlSource":"../../docs/_build/timing/7cc7de78927f0a27.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/7cc7de78927f0a27.dar-1cedf90204b189a7ba61da2ac44e27c7.svg","alt":"Error is produced after skipping more than 2 compare points","class":"hidden dark:block","key":"eRwSl7zgqu","urlSource":"../../docs/_build/timing/7cc7de78927f0a27.dark.svg"},{"type":"heading","depth":2,"position":{"start":{"line":172,"column":1},"end":{"line":172,"column":1}},"children":[{"type":"text","value":"Relative position compare","position":{"start":{"line":172,"column":1},"end":{"line":172,"column":1}},"key":"rglskJb4U3"}],"identifier":"relative-position-compare","label":"Relative position compare","html_id":"relative-position-compare","implicit":true,"key":"sobsGHFimP"},{"type":"paragraph","position":{"start":{"line":174,"column":1},"end":{"line":176,"column":1}},"children":[{"type":"text","value":"We may want to nest position compare blocks, or respond to some external event.\nIn which case, we expose the option to a position compare relative to the\nlatched position at the start:","position":{"start":{"line":174,"column":1},"end":{"line":174,"column":1}},"key":"GQ8PzWKX2R"}],"key":"pjHsw4utsf"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/ed03df080e60f700-65313e3b5a1bbc15ff8209cee4457bf2.svg","alt":"Relative position compare","class":"dark:hidden","key":"tJFT5IG0uv","urlSource":"../../docs/_build/timing/ed03df080e60f700.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/ed03df080e60f700.dar-c937cb9682dfc847099147eb038ee276.svg","alt":"Relative position compare","class":"hidden dark:block","key":"QJgv9dU8rr","urlSource":"../../docs/_build/timing/ed03df080e60f700.dark.svg"},{"type":"paragraph","position":{"start":{"line":182,"column":1},"end":{"line":182,"column":1}},"children":[{"type":"text","value":"If we want it to start immediately on ENABLE then we set START and PRE_START=0:","position":{"start":{"line":182,"column":1},"end":{"line":182,"column":1}},"key":"idFdXdnH8f"}],"key":"FmlHr4pAgd"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/2841ee37b3c803aa-890e2ed7999dd801c87e2794be38f23a.svg","alt":"Relative position compare no START","class":"dark:hidden","key":"Ia2CUAcd5j","urlSource":"../../docs/_build/timing/2841ee37b3c803aa.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/2841ee37b3c803aa.dar-13ae777df4dd1a7d3c8459c122fe9e40.svg","alt":"Relative position compare no START","class":"hidden dark:block","key":"UuRkLuPwYx","urlSource":"../../docs/_build/timing/2841ee37b3c803aa.dark.svg"},{"type":"paragraph","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"children":[{"type":"text","value":"We can also guess the direction in relative mode:","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"kPn3SCtK5A"}],"key":"oQFsO7oFpp"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/922404fa75b23865-912d97928646a9bce0b409912fc03edc.svg","alt":"Guess relative direction +ve","class":"dark:hidden","key":"o9mEVLC2Ea","urlSource":"../../docs/_build/timing/922404fa75b23865.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/922404fa75b23865.dar-dd4de699a3feb5512ba69fd8ef7626a6.svg","alt":"Guess relative direction +ve","class":"hidden dark:block","key":"QAxYSpLRk1","urlSource":"../../docs/_build/timing/922404fa75b23865.dark.svg"},{"type":"paragraph","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"children":[{"type":"text","value":"This works when going negative too:","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"dDGvOz8d0z"}],"key":"ioIt3VGFL1"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/3dc09a6891cf2ede-a4c0936e7359e19bf5ca1e47c05c3845.svg","alt":"Guess relative direction -ve","class":"dark:hidden","key":"ZbQHxj2U3G","urlSource":"../../docs/_build/timing/3dc09a6891cf2ede.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/3dc09a6891cf2ede.dar-d40762405c622a2fa61fe5931f8ff6ca.svg","alt":"Guess relative direction -ve","class":"hidden dark:block","key":"Nh8v2IiuJq","urlSource":"../../docs/_build/timing/3dc09a6891cf2ede.dark.svg"},{"type":"paragraph","position":{"start":{"line":200,"column":1},"end":{"line":201,"column":1}},"children":[{"type":"text","value":"And with a PRE_START value we guess the direction to be the opposite to the\ndirection the motor is travelling when it exceeds PRE_START:","position":{"start":{"line":200,"column":1},"end":{"line":200,"column":1}},"key":"rv7pjy0J6m"}],"key":"WhSTtwOYFY"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/5557b9681a8f62d9-9c1bbcc47a8a4f748e74456af606cd35.svg","alt":"Guess relative direction +ve with PRE_START","class":"dark:hidden","key":"g0fMK2RmH7","urlSource":"../../docs/_build/timing/5557b9681a8f62d9.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/5557b9681a8f62d9.dar-131ceba5361c5bc5123df053249edb64.svg","alt":"Guess relative direction +ve with PRE_START","class":"hidden dark:block","key":"lCh9PT8K4p","urlSource":"../../docs/_build/timing/5557b9681a8f62d9.dark.svg"},{"type":"paragraph","position":{"start":{"line":207,"column":1},"end":{"line":208,"column":1}},"children":[{"type":"text","value":"We cannot guess the direction when RELATIVE mode is set with no START or\nPRE_START though, the Block will error in this case:","position":{"start":{"line":207,"column":1},"end":{"line":207,"column":1}},"key":"vxi2JV9c9P"}],"key":"ZKVNAdMBxf"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/76abd25e08a78cff-25f00578fc2a104be60e7bcbd19c6abe.svg","alt":"Guess relative direction with no START","class":"dark:hidden","key":"vdfvgOmoWf","urlSource":"../../docs/_build/timing/76abd25e08a78cff.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/76abd25e08a78cff.dar-79268352f038aab43d2b335919dcb8d0.svg","alt":"Guess relative direction with no START","class":"hidden dark:block","key":"VWiTOMhovV","urlSource":"../../docs/_build/timing/76abd25e08a78cff.dark.svg"},{"type":"heading","depth":2,"position":{"start":{"line":214,"column":1},"end":{"line":214,"column":1}},"children":[{"type":"text","value":"Use as a Schmitt trigger","position":{"start":{"line":214,"column":1},"end":{"line":214,"column":1}},"key":"avmavU1Anw"}],"identifier":"use-as-a-schmitt-trigger","label":"Use as a Schmitt trigger","html_id":"use-as-a-schmitt-trigger","implicit":true,"key":"cd4wpe2ssa"},{"type":"paragraph","position":{"start":{"line":216,"column":1},"end":{"line":218,"column":1}},"children":[{"type":"text","value":"We can also make use of a special case with STEP=0 and a negative WIDTH to\ncreate a Schmitt trigger that will always trigger at START, and turn off when\nINP has dipped WIDTH below START:","position":{"start":{"line":216,"column":1},"end":{"line":216,"column":1}},"key":"hO80hwEaIQ"}],"key":"nrHH38SPER"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/a5bac6d08c368155-00c92a7ac41c7cd06d957adeb4da6885.svg","alt":"Schmitt trigger","class":"dark:hidden","key":"A642ZRwAlE","urlSource":"../../docs/_build/timing/a5bac6d08c368155.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/a5bac6d08c368155.dar-05090b1f418967380ef88bf8432a8251.svg","alt":"Schmitt trigger","class":"hidden dark:block","key":"pu7pgNsEcX","urlSource":"../../docs/_build/timing/a5bac6d08c368155.dark.svg"},{"type":"paragraph","position":{"start":{"line":224,"column":1},"end":{"line":226,"column":1}},"children":[{"type":"text","value":"We can use this same special case with a positive width to make a similar\ncomparator that turns on at START and off at START+WIDTH, triggering again\nwhen INP <= START:","position":{"start":{"line":224,"column":1},"end":{"line":224,"column":1}},"key":"lVVlXRwKyz"}],"key":"E8rflhti8T"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/d01547de183cab52-bdc0287d2e550424734385ea9ac281e3.svg","alt":"Repeating comparator","class":"dark:hidden","key":"QsyH6WijMF","urlSource":"../../docs/_build/timing/d01547de183cab52.svg"},{"type":"image","url":"/PandABlocks-FPGA/docs/build/d01547de183cab52.dar-b397c045112901e4b78207eacee52692.svg","alt":"Repeating comparator","class":"hidden dark:block","key":"C7csbvZPhV","urlSource":"../../docs/_build/timing/d01547de183cab52.dark.svg"}],"key":"adM0ezGtox"}],"key":"Sypu6TXdbT"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"PCAP - Position Capture","url":"/pcap-doc","group":"PandABlocks-FPGA"},"next":{"title":"PGEN - Position Generator","url":"/pgen-doc","group":"PandABlocks-FPGA"}}},"domain":"http://localhost:3000"}